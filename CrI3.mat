#===================================================
# CrI3 bilayer material file for Vampire
#===================================================

#---------------------------------------------------
# Number of Materials
#---------------------------------------------------
material:num-materials=2
#---------------------------------------------------
# Material 1: Cr in layer 1
#   height 0.0 - 0.5 (lower half of simulation cell)
#---------------------------------------------------
material[1]:material-name=CrI3_layer1
material[1]:damping-constant=1.0
material[1]:exchange-matrix[1]=3.524e-22 !J
material[1]:exchange-matrix[2]=-2.8e-23 !J
material[1]:atomic-spin-moment=3.0 !muB
material[1]:second-order-uniaxial-anisotropy-constant=1.44e-23 !J
material[1]:uniaxial-anisotropy-direction=0,0,1
material[1]:material-element=Cr
material[1]:minimum-height=0.0
material[1]:maximum-height=0.5

#---------------------------------------------------
# Material 2: Cr in layer 2
#   height 0.5 - 1.0 (upper half of simulation cell)
#   Exchange matrix is transposed relative to mat 1
#---------------------------------------------------
material[2]:material-name=CrI3_layer2
material[2]:damping-constant=1.0
material[2]:exchange-matrix[1]=-2.8e-23 !J
material[2]:exchange-matrix[2]=3.524e-22 !J
material[2]:atomic-spin-moment=3.0 !muB
material[2]:second-order-uniaxial-anisotropy-constant=1.44e-23 !J
material[2]:uniaxial-anisotropy-direction=0,0,1
material[2]:material-element=Cr
material[2]:minimum-height=0.5
material[2]:maximum-height=1.0
